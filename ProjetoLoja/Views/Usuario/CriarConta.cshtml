@model ProjetoLoja.Models.LoginViewModel


<div class="container mt-5">
    <h2>Crie sua conta</h2>
    <form asp-action="CriarConta" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label>Nome</label>
            <input asp-for="Nome" class="form-control" type="Nome" required />
        </div>
        <div class="mb-3">
            <label>E-mail</label>
            <input asp-for="Email" class="form-control" type="email" required />
        </div>

        <div class="mb-3">
            <label>Senha</label>
            <input asp-for="Senha" class="form-control" type="password" required />
        </div>

        <button type="submit" class="btn btn-success">Cadastrar</button>
        <a asp-action="Login" class="btn btn-link">Já tenho conta</a>
    </form>
</div>